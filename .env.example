# Copy to .env (project root). ADK loads it automatically.

# --- Option A: native Gemini (Google AI Studio key) ---
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your-api-key-here
# E2E_AGENT_MODEL=gemini-2.5-flash
# E2E_CODER_MODEL=gemini-2.5-pro

# --- Option B: OpenRouter (any "openrouter/<vendor>/<model>" id) ---
# OPENROUTER_API_KEY=sk-or-v1-...
# E2E_AGENT_MODEL=openrouter/google/gemini-2.5-flash
# E2E_CODER_MODEL=openrouter/anthropic/claude-sonnet-4.5
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1  # only to override the default
# E2E_MAX_ITERATIONS=4
# E2E_HEADLESS=1
# E2E_ACTION_TIMEOUT_MS=10000
